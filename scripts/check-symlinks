#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/check-symlinks [--target PATH]
EOF
}

TARGET="."

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      TARGET="${2:?--target requires a path}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
CANONICAL="$(cd "$SCRIPT_DIR/.." && pwd -P)"

if [[ ! -d "$TARGET" ]]; then
  echo "error: target repo does not exist: $TARGET" >&2
  exit 1
fi
TARGET="$(cd "$TARGET" && pwd -P)"

resolve_path() {
  python3 - "$1" <<'PY'
import os
import sys
print(os.path.realpath(sys.argv[1]))
PY
}

source_for() {
  local base="$1"
  local name="$2"

  case "$base/$name" in
    .agents/model-router|.cursor/model-router)
      echo "$CANONICAL"
      ;;
    .codex/*|.claude/*)
      echo "$CANONICAL/$base/skills/$name"
      ;;
    *)
      echo "error: no source configured for $base/skills/$name" >&2
      return 1
      ;;
  esac
}

check_one() {
  local base="$1"
  local name="$2"
  local dest="$TARGET/$base/skills/$name"
  local source resolved source_resolved

  source="$(source_for "$base" "$name")"
  if [[ ! -e "$source" ]]; then
    echo "missing-source: $source"
    return 1
  fi
  source_resolved="$(resolve_path "$source")"

  if [[ ! -L "$dest" ]]; then
    echo "missing-or-not-symlink: $dest"
    return 1
  fi

  if [[ ! -e "$dest" ]]; then
    echo "broken: $dest"
    return 1
  fi

  resolved="$(resolve_path "$dest")"
  if [[ "$resolved" != "$source_resolved" ]]; then
    echo "wrong-target: $dest -> $resolved"
    return 1
  fi

  echo "ok: $dest -> $source"
}

echo "canonical: $CANONICAL"
echo "target: $TARGET"

check_one ".agents" "model-router"
check_one ".cursor" "model-router"

for skill in \
  "model-router" \
  "tdd-implementation-packet" \
  "cursor-delegate" \
  "opencode-delegate" \
  "codex-delegate"
do
  check_one ".codex" "$skill"
  check_one ".claude" "$skill"
done
