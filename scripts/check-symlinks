#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/check-symlinks [--target PATH]
EOF
}

TARGET="."

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      TARGET="${2:?--target requires a path}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
CANONICAL="$(cd "$SCRIPT_DIR/.." && pwd -P)"

if [[ ! -d "$TARGET" ]]; then
  echo "error: target repo does not exist: $TARGET" >&2
  exit 1
fi
TARGET="$(cd "$TARGET" && pwd -P)"

resolve_path() {
  python3 - "$1" <<'PY'
import os
import sys
print(os.path.realpath(sys.argv[1]))
PY
}

source_for() {
  local base="$1"
  local name="$2"

  case "$base" in
    .agents|.cursor|.codex|.claude) ;;
    *)
      echo "error: no source configured for $base/skills/$name" >&2
      return 1
      ;;
  esac

  echo "$CANONICAL/skills/$name"
}

check_no_ancestor_links() {
  local base link resolved
  shopt -s nullglob
  for base in .agents .cursor .codex .claude; do
    for link in "$TARGET/$base/skills"/*; do
      [[ -L "$link" ]] || continue
      resolved="$(resolve_path "$link")"
      if [[ "$link/" == "$resolved/"* ]]; then
        echo "ancestor-pointing: $link -> $resolved"
        return 1
      fi
    done
  done
}

check_link() {
  local dest="$1"
  local source="$2"
  local resolved source_resolved

  if [[ ! -e "$source" ]]; then
    echo "missing-source: $source"
    return 1
  fi
  source_resolved="$(resolve_path "$source")"

  if [[ ! -L "$dest" ]]; then
    echo "missing-or-not-symlink: $dest"
    return 1
  fi

  if [[ ! -e "$dest" ]]; then
    echo "broken: $dest"
    return 1
  fi

  resolved="$(resolve_path "$dest")"
  if [[ "$resolved" != "$source_resolved" ]]; then
    echo "wrong-target: $dest -> $resolved"
    return 1
  fi

  echo "ok: $dest -> $source"
}

check_one() {
  local base="$1"
  local name="$2"
  check_link "$TARGET/$base/skills/$name" "$(source_for "$base" "$name")"
}

check_script() {
  local name="$1"
  check_link "$TARGET/scripts/$name" "$CANONICAL/scripts/$name"
}

echo "canonical: $CANONICAL"
echo "target: $TARGET"

check_no_ancestor_links
check_one ".agents" "model-router"
for skill in \
  "model-router" \
  "tdd-implementation-packet" \
  "cursor-delegate" \
  "pi-delegate" \
  "codex-delegate"
do
  check_one ".cursor" "$skill"
done

for skill in \
  "model-router" \
  "tdd-implementation-packet" \
  "cursor-delegate" \
  "pi-delegate" \
  "codex-delegate"
do
  check_one ".codex" "$skill"
  check_one ".claude" "$skill"
done

for script in \
  "run-delegate" \
  "delegate-snapshot" \
  "delegate-delta" \
  "check-packet" \
  "check-report" \
  "extract-report" \
  "router-log" \
  "router-log-summary"
do
  check_script "$script"
done
