#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/install-symlinks [--target PATH] [--force]
EOF
}

TARGET="."
FORCE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      TARGET="${2:?--target requires a path}"
      shift 2
      ;;
    --force)
      FORCE=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
CANONICAL="$(cd "$SCRIPT_DIR/.." && pwd -P)"

if [[ ! -d "$TARGET" ]]; then
  echo "error: target repo does not exist: $TARGET" >&2
  exit 1
fi
TARGET="$(cd "$TARGET" && pwd -P)"

resolve_path() {
  python3 - "$1" <<'PY'
import os
import sys
print(os.path.realpath(sys.argv[1]))
PY
}

timestamp() {
  date -u +%Y%m%dT%H%M%SZ
}

source_for() {
  local base="$1"
  local name="$2"

  case "$base" in
    .agents|.cursor|.codex|.claude) ;;
    *)
      echo "error: no source configured for $base/skills/$name" >&2
      return 1
      ;;
  esac

  echo "$CANONICAL/skills/$name"
}

link_path() {
  local dest="$1"
  local source="$2"
  local parent resolved source_resolved backup

  if [[ ! -e "$source" ]]; then
    echo "error: source does not exist: $source" >&2
    return 1
  fi
  source_resolved="$(resolve_path "$source")"
  parent="$(dirname "$dest")"

  if [[ ! -d "$parent" ]]; then
    mkdir -p "$parent"
    echo "created-dir: $parent"
  fi

  if [[ -L "$dest" ]]; then
    resolved="$(resolve_path "$dest")"
    if [[ "$resolved" == "$source_resolved" ]]; then
      echo "skipped: $dest -> $source"
      return
    fi

    if [[ -e "$dest" && "$FORCE" -ne 1 ]]; then
      echo "blocked: $dest points to $resolved; use --force to replace"
      return 1
    fi

    if [[ ! -e "$dest" ]]; then
      rm "$dest"
      ln -s "$source" "$dest"
      echo "replaced-broken-symlink: $dest -> $source"
      return
    fi

    backup="$dest.backup.$(timestamp)"
    mv "$dest" "$backup"
    echo "backed-up: $dest -> $backup"
    ln -s "$source" "$dest"
    echo "replaced: $dest -> $source"
    return
  fi

  if [[ -e "$dest" ]]; then
    if [[ "$FORCE" -ne 1 ]]; then
      echo "blocked: $dest exists; use --force to replace"
      return 1
    fi
    backup="$dest.backup.$(timestamp)"
    mv "$dest" "$backup"
    echo "backed-up: $dest -> $backup"
    ln -s "$source" "$dest"
    echo "replaced: $dest -> $source"
    return
  fi

  ln -s "$source" "$dest"
  echo "created: $dest -> $source"
}

install_one() {
  local base="$1"
  local name="$2"
  link_path "$TARGET/$base/skills/$name" "$(source_for "$base" "$name")"
}

install_script() {
  local name="$1"
  link_path "$TARGET/scripts/$name" "$CANONICAL/scripts/$name"
}

echo "canonical: $CANONICAL"
echo "target: $TARGET"

install_one ".agents" "model-router"
for skill in \
  "model-router" \
  "tdd-implementation-packet" \
  "cursor-delegate" \
  "pi-delegate" \
  "codex-delegate"
do
  install_one ".cursor" "$skill"
done

for skill in \
  "model-router" \
  "tdd-implementation-packet" \
  "cursor-delegate" \
  "pi-delegate" \
  "codex-delegate"
do
  install_one ".codex" "$skill"
  install_one ".claude" "$skill"
done

# Skills invoke these as worktree-relative `scripts/...`; keep them wired to
# the canonical router so any task worktree can dispatch without improvising.
for script in \
  "run-delegate" \
  "delegate-snapshot" \
  "delegate-delta" \
  "check-packet" \
  "check-report" \
  "extract-report" \
  "router-log" \
  "router-log-summary"
do
  install_script "$script"
done
