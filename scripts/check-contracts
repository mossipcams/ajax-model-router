#!/usr/bin/env bash
set -euo pipefail

# Resolve through symlinks so installed copies still find this repo.
ROOT="$(cd "$(dirname "$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "${BASH_SOURCE[0]}")")/.." && pwd -P)"
ROUTER="skills/model-router/SKILL.md"
failures=0

require_text() {
  local file="$1" text="$2" label="$3"
  if ! grep -Fq -- "$text" "$ROOT/$file"; then
    echo "missing: $label" >&2
    failures=$((failures + 1))
  fi
}

forbid_text() {
  local file="$1" text="$2" label="$3"
  if grep -Fq -- "$text" "$ROOT/$file"; then
    echo "forbidden: $label" >&2
    failures=$((failures + 1))
  fi
}

require_count() {
  local text="$1" expected="$2" label="$3" actual
  actual="$( (grep -RohF --include='SKILL.md' -- "$text" "$ROOT/skills" || true) | wc -l | tr -d ' ')"
  if [[ "$actual" != "$expected" ]]; then
    echo "wrong-count: $label (expected $expected, got $actual)" >&2
    failures=$((failures + 1))
  fi
}

for field in ACTION LANE MODE MODEL PACKET_STATUS PACKET_REBUILD_COUNT PACKET_CRITIQUE_COUNT ALLOWED_SCOPE REASON ESCALATE_IF; do
  require_text "$ROUTER" "$field:" "routing decision field $field"
done

require_text "$ROUTER" "## Model Registry" "central model registry"
require_text "$ROUTER" "CRITIQUE_PACKET" "packet critique action"
require_text "$ROUTER" "tdd-implementation-packet" "packet builder lane"
require_text "$ROUTER" "Emit a new decision after each action." "single-step binding rule"
for key in CODEX CURSOR MINIMAX GLM; do
  model_id="$(awk -F'`' -v key="$key" '$2 == key {print $4; exit}' "$ROOT/$ROUTER")"
  if [[ -z "$model_id" ]]; then
    echo "missing: model registry key $key" >&2
    failures=$((failures + 1))
  else
    require_count "$model_id" 1 "$key model ID outside registry"
  fi
done

require_text "$ROUTER" "Risk and reasoning depth take precedence over file category." "routing precedence rule"
require_text "$ROUTER" "Tests-only work keeps the lane selected by reasoning depth." "tests-only complexity rule"
require_text "$ROUTER" 'Any required evidence category is missing' "missing-evidence route"
require_text "$ROUTER" '`GATHER_EVIDENCE`' "evidence action"
require_text "$ROUTER" '`evidence`' "evidence mode"
require_text "$ROUTER" 'parent-local and read-only' "local evidence gathering"
require_text "$ROUTER" 'round revises on `GLM`' "failed-round lane escalation"

risk_line="$(grep -nF 'Authentication, security, data-loss, backend, server, session, PTY, or supervisor work' "$ROOT/$ROUTER" | head -1 | cut -d: -f1 || true)"
frontend_line="$(grep -nF 'Frontend UI behavior with bounded files and anchors' "$ROOT/$ROUTER" | head -1 | cut -d: -f1 || true)"
if [[ -z "$risk_line" || -z "$frontend_line" || "$risk_line" -ge "$frontend_line" ]]; then
  echo "wrong-order: risk/backend route must precede frontend route" >&2
  failures=$((failures + 1))
fi

packet="skills/tdd-implementation-packet/SKILL.md"
require_text "$packet" "PACKET_STATUS: READY | BLOCKED" "packet readiness status"
require_text "$packet" "TASK_KIND: behavior | tests-only | docs-only | mechanical" "packet task kind"
require_text "$packet" "TEST_FIRST: REQUIRED | NOT_APPLICABLE" "conditional test-first field"
require_text "$packet" "PRODUCTION_EDIT: REQUIRED | FORBIDDEN" "conditional production field"
require_text "$packet" 'A missing required evidence category makes the packet `BLOCKED`' "blocked packet rule"
require_text "$packet" '| `docs-only` | `NOT_APPLICABLE` | `FORBIDDEN` |' "docs-only requirements"
require_text "$packet" '| `tests-only` | `NOT_APPLICABLE` | `FORBIDDEN` |' "tests-only requirements"
forbid_text "$packet" "state the missing input as a stop condition" "missing context hidden in stop conditions"
require_text "$packet" "never whole files" "packet evidence excerpt cap"

for adapter in cursor-delegate pi-delegate codex-delegate; do
  file="skills/$adapter/SKILL.md"
  require_text "$file" "ROUTING_DECISION" "$adapter requires router binding"
  require_text "$file" 'return `STOP`' "$adapter unavailable-tool behavior"
done

cursor="skills/cursor-delegate/SKILL.md"
require_text "$cursor" 'mode: `implement` or `test-only`' "Cursor mode contract"
require_text "$cursor" 'Resume keeps the original mode' "Cursor resume semantics"
forbid_text "$cursor" '`review`' "unroutable Cursor review mode"
forbid_text "$cursor" '`small-fix`' "duplicate Cursor small-fix mode"

implicit_false_count="$( (grep -RohF --include='openai.yaml' -- 'allow_implicit_invocation: false' "$ROOT/skills" || true) | wc -l | tr -d ' ')"
if [[ "$implicit_false_count" != "3" ]]; then
  echo "wrong-count: delegate implicit activation guards (expected 3, got $implicit_false_count)" >&2
  failures=$((failures + 1))
fi
forbid_text "skills/cursor-delegate/agents/openai.yaml" "allow_implicit_invocation: true" "Cursor implicit activation"

codex="skills/codex-delegate/SKILL.md"
forbid_text "$ROUTER" "delegator" "second orchestrator route"
forbid_text "$codex" "delegator" "Codex delegator mode"
require_text "$ROUTER" 'Standalone review uses `PACKET_STATUS: NOT_REQUIRED`' "standalone review packet rule"
require_text "$ROUTER" 'performs the review locally' "orchestrator-owned final review"
require_text "$ROUTER" "regressions, security, error handling, test gaps, and cross-file integration" "local final review scope"
require_text "$codex" '`packet-critique` or `implementation`' "Codex mode set"
forbid_text "$codex" 'diff-review' "duplicate diff-review gate"
forbid_text "$codex" 'final-review' "delegated final review mode"
require_text "$ROUTER" '| `CODEX` | `gpt-5.6-sol` |' "Codex model registry value"
require_text "$codex" '--reasoning-effort xhigh' "Codex xhigh reasoning override"
require_text "$codex" '--tool codex' "Codex routed through the shared app-server runner"
forbid_text "$ROUTER" 'diff-review' "duplicate diff-review route"
forbid_text "$ROUTER" 'final-review' "delegated final review route"
require_text "$ROUTER" 'Packet critique applies only to `CODEX` and `GLM` implementation lanes and only' "critique uncertainty restriction"
require_text "$codex" "PACKET_REVIEW" "Codex packet review schema"

pi="skills/pi-delegate/SKILL.md"
require_text "$pi" 'Headless only.' "Pi headless-only note"
require_text "$pi" 'pi --mode rpc --model "$MODEL" --no-session --no-context-files --no-skills' "Pi verified invocation"
require_text "$pi" 'scripts/run-delegate --tool pi' "Pi bounded runner"
require_text "$pi" 'Exit `124`' "Pi delegate timeout status"

require_text "$ROUTER" "DELEGATE_REPORT:" "structured delegate report"
require_text "$ROUTER" "REVIEW_REPORT:" "structured review report"
require_text "$ROUTER" "PHASE: RED | GREEN | VERIFY | OTHER" "command evidence phase"
require_text "$ROUTER" "EXIT_CODE:" "command evidence exit code"
require_text "$ROUTER" "OUTPUT_EXCERPT:" "command evidence output"
require_text "$ROUTER" "A success claim without command evidence is failure." "evidence enforcement"
require_text "$ROUTER" "## Pre-dispatch Snapshot" "delegate baseline snapshot"
require_text "$ROUTER" 'scripts/delegate-snapshot "$SNAP" pre' "pre snapshot command"
require_text "$ROUTER" 'scripts/delegate-delta inspect "$SNAP"' "delta inspection command"
require_text "$ROUTER" 'scripts/delegate-delta restore "$SNAP"' "delta restore command"
require_text "$ROUTER" "Delegate write finished and its delta is not yet gated" "local gate route"
require_text "$ROUTER" "DISCARD is a verdict, not permission to reset the worktree." "safe discard definition"
require_text "$ROUTER" "complete current" "concurrent edit guard"
require_text "$ROUTER" 'Never use `git reset`' "destructive restore guard"
forbid_text "$ROUTER" "Return a REPORT with:" "unstructured delegate report"
forbid_text "$ROUTER" "Implement exactly one behavior change" "behavior-only delegate prompt"
require_text "$ROUTER" "Complete exactly one bounded task from the packet below." "task-kind-neutral delegate prompt"
require_text "README.md" "scripts/check-contracts" "contract validator documentation"
require_text "$ROUTER" "## Routing Calibration Log" "calibration log"
require_text "$ROUTER" "## Routing Calibration" "calibration procedure"
require_text "$ROUTER" "Frozen calibration controls:" "frozen calibration list"
require_text "$ROUTER" "No tripwire, no edit." "calibration regularizer"
require_text "CALIBRATION.md" "# Routing Calibration Ledger" "calibration checkpoint ledger"

if ! bash -n "$ROOT"/scripts/*; then
  echo "failed: shell syntax" >&2
  failures=$((failures + 1))
fi
if ! python3 -m unittest discover -s "$ROOT/tests" -p 'test_*.py'; then
  echo "failed: behavioral contracts" >&2
  failures=$((failures + 1))
fi

if ((failures > 0)); then
  exit 1
fi

echo "contract checks passed"
